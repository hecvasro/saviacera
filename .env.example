# Saviacera — copy this file to `.env` (or `.env.local`) and fill in real values.
# Anything prefixed with PUBLIC_ is exposed to the browser. Do NOT put secrets here.

# Google Apps Script Web App URL that receives orders and appends them to the
# "Orders" sheet. See apps-script/Code.gs and README.md for setup instructions.
PUBLIC_ORDER_ENDPOINT="https://script.google.com/macros/s/REPLACE_ME/exec"

# WhatsApp number used for the wa.me deep link on the cart page.
# Format: country code + number, digits only (no +, spaces, or dashes).
PUBLIC_WHATSAPP_NUMBER="18295286271"
