---
const { pathname } = Astro.url;
const navItems = [
  { href: "/aromaticos", label: "Aromáticos" },
  { href: "/cuidado-personal", label: "Cuidado personal" },
  { href: "/sets", label: "Sets" },
  { href: "/personalizados", label: "Personalizados" },
];
---

<header class="bg-primary sticky top-0 z-30">
  <div class="container-page flex items-center justify-between gap-4 py-3">
    <a href="/" class="flex items-center" aria-label="Saviacera — inicio">
      <img
        src="/logo.png"
        alt="Saviacera — velas, jabones y kits artesanales"
        class="h-10 md:h-12 w-auto block"
        decoding="async"
        loading="eager"
      />
    </a>

    <nav
      class="hidden md:flex items-center gap-6 md:gap-8 text-lg text-primary-contrast"
    >
      {
        navItems.map((item) => {
          const active = pathname.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                "transition-opacity hover:opacity-70",
                active ? "opacity-100 font-medium" : "opacity-90",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/carrito"
        class="relative inline-flex items-center gap-2 rounded-md border border-primary-contrast/60 px-3 py-2 text-base md:text-lg text-primary-contrast hover:bg-primary-contrast/10 transition-colors"
        aria-label="Ver carrito"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          class="h-5 w-5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.7 5h13.4M9 21a1 1 0 11-2 0 1 1 0 012 0zm10 0a1 1 0 11-2 0 1 1 0 012 0z"
          ></path>
        </svg>
        <span class="hidden md:inline">Carrito</span>
        <span
          data-cart-count
          class="ml-1 hidden min-w-[1.5rem] rounded-full bg-accent px-1.5 py-0.5 text-center text-xs text-accent-contrast"
          >0</span
        >
      </a>

      <button
        type="button"
        data-nav-toggle
        aria-label="Abrir menú"
        aria-controls="mobile-nav"
        aria-expanded="false"
        class="md:hidden inline-flex items-center justify-center rounded-md border border-primary-contrast/60 p-2 text-primary-contrast hover:bg-primary-contrast/10 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="h-6 w-6"
          data-nav-icon="open"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="h-6 w-6 hidden"
          data-nav-icon="close"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 6l12 12M6 18 18 6"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    role="navigation"
    aria-label="Navegación móvil"
    data-nav-panel
    hidden
    class="md:hidden bg-primary border-t border-primary-contrast/20 text-primary-contrast"
  >
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="block px-5 py-4 text-lg border-b border-primary-contrast/20 last:border-b-0 hover:bg-primary-contrast/10 transition-colors"
          data-nav-link
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  import { getCartCount } from "~/lib/cart";

  function refresh() {
    const el = document.querySelector<HTMLElement>("[data-cart-count]");
    if (!el) return;
    const n = getCartCount();
    el.textContent = String(n);
    el.classList.toggle("hidden", n === 0);
  }

  function setupNav() {
    const btn = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
    const panel = document.querySelector<HTMLElement>("[data-nav-panel]");
    if (!btn || !panel) return;
    if (btn.dataset.bound === "1") return;
    btn.dataset.bound = "1";

    const iconOpen = btn.querySelector<HTMLElement>('[data-nav-icon="open"]');
    const iconClose = btn.querySelector<HTMLElement>('[data-nav-icon="close"]');

    btn.addEventListener("click", () => {
      const willOpen = panel.hasAttribute("hidden");
      if (willOpen) panel.removeAttribute("hidden");
      else panel.setAttribute("hidden", "");
      btn.setAttribute("aria-expanded", String(willOpen));
      btn.setAttribute("aria-label", willOpen ? "Cerrar menú" : "Abrir menú");
      iconOpen?.classList.toggle("hidden", willOpen);
      iconClose?.classList.toggle("hidden", !willOpen);
      if (willOpen) {
        panel.querySelector<HTMLAnchorElement>("[data-nav-link]")?.focus();
      }
    });
  }

  refresh();
  setupNav();
  window.addEventListener("saviacera:cart-changed", refresh);
  document.addEventListener("astro:page-load", () => {
    refresh();
    setupNav();
  });
</script>
