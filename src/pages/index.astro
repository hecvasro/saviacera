---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";

const all = await getCollection("products", ({ data }) => data.available);
const featuredSets = all
  .filter((p) => p.data.category === "sets" && p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const featuredOther = all
  .filter((p) => p.data.category !== "sets" && p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative">
    <div class="container-page py-16 md:py-24 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="chip">Hecho a mano · RD</p>
        <h1 class="mt-4 font-display text-5xl md:text-6xl leading-tight">
          Pequeños rituales,<br />grandes momentos.
        </h1>
        <p class="mt-5 text-lg text-muted max-w-md">
          Velas aromáticas de origen vegetal, jabones artesanales y kits
          pensados para regalar — o regalarte. Hechos a mano en República
          Dominicana.
        </p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <a href="/sets" class="btn btn-primary">Ver sets de temporada</a>
          <a href="/productos" class="btn btn-secondary"
            >Ver todos los productos</a
          >
        </div>
      </div>
      <div class="aspect-[4/5] rounded-lg overflow-hidden bg-surface shadow-md">
        <img
          src="https://picsum.photos/seed/saviacera-hero/900/1100"
          alt="Velas y jabones Saviacera"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Featured sets -->
  {
    featuredSets.length > 0 && (
      <section class="container-page py-12">
        <div class="flex items-end justify-between mb-6">
          <div>
            <p class="chip">Temporada</p>
            <h2 class="mt-2 font-display text-3xl">Sets destacados</h2>
          </div>
          <a href="/sets" class="text-sm text-accent hover:underline">
            Ver todos →
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredSets.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </section>
    )
  }

  <!-- Featured velas/jabones -->
  {
    featuredOther.length > 0 && (
      <section class="container-page py-12">
        <h2 class="font-display text-3xl mb-6">Favoritos</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredOther.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </section>
    )
  }

  <!-- Brand story stub -->
  <section class="bg-surface-muted mt-16 border-y border-border">
    <div class="container-page py-16 grid md:grid-cols-2 gap-10 items-center">
      <div class="aspect-square rounded-lg overflow-hidden">
        <img
          src="https://picsum.photos/seed/saviacera-story/800/800"
          alt="Detrás de Saviacera"
          class="h-full w-full object-cover"
        />
      </div>
      <div>
        <p class="chip">Nuestra historia</p>
        <h2 class="mt-3 font-display text-3xl">
          De nuestras manos, a tu alma
        </h2>
        <p class="mt-4 text-muted text-justify">
          <em>Savia &amp; Cera</em> es el resultado de un sueño que comenzó
          entre las paredes de mi hogar, en ese rincón donde el tiempo
          parece detenerse para dar paso a la creación. Lo que empezó como
          un anhelo personal se transformó en un compromiso: el de diseñar
          productos con <strong>alma e intención</strong>, capaces de
          habitar tus espacios y acompañar tus momentos especiales.
        </p>
        <p class="mt-3 text-muted text-justify">
          Para nosotros, crear no es un proceso en serie, es un acto de
          amor. Cada fragancia, cada vela y cada jabón han sido pensados
          para aportar armonía a tu día a día, transformando lo simple en
          un ritual con propósito. En cada orden compartimos un pedazo de
          nuestra historia y la dedicación de nuestras manos.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
