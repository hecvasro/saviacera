---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";

const velas = (
  await getCollection("products", ({ data }) => data.category === "velas" && data.available)
).sort((a, b) => a.data.order - b.data.order);

// Build a unique tag list for the filter UI.
const tagSet = new Set<string>();
velas.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
const tags = Array.from(tagSet).sort();
---

<BaseLayout title="Velas — Saviacera">
  <section class="container-page py-10">
    <p class="chip">Catálogo</p>
    <h1 class="mt-3 font-display text-4xl">Velas</h1>
    <p class="mt-2 text-muted max-w-xl">
      Cera de soya 100%, mecha de algodón y aromas elaborados con aceites
      esenciales. Pequeñas tandas, hechas a mano.
    </p>

    {
      tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2" data-tag-filter>
          <button
            type="button"
            class="chip chip-active"
            data-tag-button
            data-tag="__all__"
          >
            Todas
          </button>
          {tags.map((t) => (
            <button type="button" class="chip" data-tag-button data-tag={t}>
              {t}
            </button>
          ))}
        </div>
      )
    }

    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-5" data-product-grid>
      {
        velas.map((p) => (
          <div data-product data-tags={p.data.tags.join(",")}>
            <ProductCard product={p} />
          </div>
        ))
      }
    </div>

    {
      velas.length === 0 && (
        <p class="text-muted mt-8">No hay velas disponibles por ahora.</p>
      )
    }
  </section>
</BaseLayout>

<script>
  function setupFilter() {
    const filter = document.querySelector<HTMLElement>("[data-tag-filter]");
    if (!filter) return;

    filter.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest<HTMLButtonElement>("[data-tag-button]");
      if (!button) return;

      filter
        .querySelectorAll<HTMLElement>("[data-tag-button]")
        .forEach((b) => b.classList.remove("chip-active"));
      button.classList.add("chip-active");

      const tag = button.dataset.tag;
      const cards = document.querySelectorAll<HTMLElement>("[data-product]");
      cards.forEach((c) => {
        const cardTags = (c.dataset.tags || "").split(",");
        const show = tag === "__all__" || cardTags.includes(tag || "");
        c.classList.toggle("hidden", !show);
      });
    });
  }

  setupFilter();
  document.addEventListener("astro:page-load", setupFilter);
</script>
