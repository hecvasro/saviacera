---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";

const AROMATICOS = ["velas", "ambientadores", "difusores"] as const;
type Sub = (typeof AROMATICOS)[number];

const items = (
  await getCollection(
    "products",
    ({ data }) =>
      (AROMATICOS as readonly string[]).includes(data.category) &&
      data.available,
  )
).sort((a, b) => a.data.order - b.data.order);

const subcatLabels: Record<Sub, string> = {
  velas: "Velas",
  ambientadores: "Ambientadores",
  difusores: "Difusores",
};

// Show a chip only for subcategories that actually have at least one product
// — keeps the filter UI honest before the catalog is fully populated.
const presentSubcats: Sub[] = AROMATICOS.filter((c) =>
  items.some((p) => p.data.category === c),
);
---

<BaseLayout title="Aromáticos — Savia & Cera">
  <section class="container-page py-10">
    <p class="chip">Catálogo</p>
    <h1 class="mt-3 font-display text-4xl">Aromáticos</h1>
    <p class="mt-2 text-muted max-w-xl">
      Velas, ambientadores y difusores hechos a mano con fragancias naturales
      para perfumar tus espacios con intención.
    </p>

    {
      presentSubcats.length > 1 && (
        <div class="mt-6 flex flex-wrap gap-2" data-subcat-filter>
          <button
            type="button"
            class="chip chip-active"
            data-subcat-button
            data-subcat="__all__"
          >
            Todos
          </button>
          {presentSubcats.map((c) => (
            <button
              type="button"
              class="chip"
              data-subcat-button
              data-subcat={c}
            >
              {subcatLabels[c]}
            </button>
          ))}
        </div>
      )
    }

    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        items.map((p) => (
          <div data-product data-subcat={p.data.category}>
            <ProductCard product={p} />
          </div>
        ))
      }
    </div>

    {
      items.length === 0 && (
        <p class="text-muted mt-8">
          Pronto agregaremos nuestros productos aromáticos.
        </p>
      )
    }
  </section>
</BaseLayout>

<script>
  function setupFilter() {
    const filter = document.querySelector<HTMLElement>("[data-subcat-filter]");
    if (!filter) return;
    if ((filter as HTMLElement & { __bound?: boolean }).__bound) return;
    (filter as HTMLElement & { __bound?: boolean }).__bound = true;

    filter.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest<HTMLButtonElement>("[data-subcat-button]");
      if (!button) return;

      filter
        .querySelectorAll<HTMLElement>("[data-subcat-button]")
        .forEach((b) => b.classList.remove("chip-active"));
      button.classList.add("chip-active");

      const sub = button.dataset.subcat;
      const cards = document.querySelectorAll<HTMLElement>("[data-product]");
      cards.forEach((c) => {
        const cat = c.dataset.subcat || "";
        const show = sub === "__all__" || cat === sub;
        c.classList.toggle("hidden", !show);
      });
    });
  }

  setupFilter();
  document.addEventListener("astro:page-load", setupFilter);
</script>
