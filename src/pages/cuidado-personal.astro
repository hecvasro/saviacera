---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";

// Currently only jabones — when more personal-care categories land
// (aceites, bálsamos, etc.) extend this array and add a chip filter à la
// /aromaticos.
const CUIDADO_PERSONAL = ["jabones"] as const;

const items = (
  await getCollection(
    "products",
    ({ data }) =>
      (CUIDADO_PERSONAL as readonly string[]).includes(data.category) &&
      data.available,
  )
).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Cuidado personal — Savia & Cera">
  <section class="container-page py-10">
    <p class="chip">Catálogo</p>
    <h1 class="mt-3 font-display text-4xl">Cuidado personal</h1>
    <p class="mt-2 text-muted max-w-xl">
      Jabones artesanales hechos en frío, con ingredientes naturales y
      curados por al menos cuatro semanas para una espuma cremosa y una
      larga duración.
    </p>

    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((p) => <ProductCard product={p} />)}
    </div>

    {
      items.length === 0 && (
        <p class="text-muted mt-8">
          Pronto agregaremos nuevos productos de cuidado personal.
        </p>
      )
    }
  </section>
</BaseLayout>
