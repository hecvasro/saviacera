---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";

const all = (
  await getCollection("products", ({ data }) => data.available)
).sort((a, b) => a.data.order - b.data.order);

// Umbrella sections mirror the top-nav structure. Each umbrella aggregates
// one or more product `category` slugs. "Otros" is the catch-all bucket —
// the wife uses it for products that don't yet fit a defined umbrella, and
// there is no dedicated /otros page (everything lives here on /productos).
type Section = {
  title: string;
  href?: string; // omit when there's no umbrella listing page
  cats: string[];
};

const sections: Section[] = [
  {
    title: "Aromáticos",
    href: "/aromaticos",
    cats: ["velas", "ambientadores", "difusores"],
  },
  { title: "Cuidado personal", href: "/cuidado-personal", cats: ["jabones"] },
  { title: "Sets", href: "/sets", cats: ["sets"] },
  { title: "Otros", cats: ["otros"] }, // no umbrella page; everything visible here
];
---

<BaseLayout title="Productos — Savia & Cera">
  <section class="container-page py-10">
    <p class="chip">Catálogo</p>
    <h1 class="mt-3 font-display text-4xl">Productos</h1>
    <p class="mt-2 text-muted max-w-xl">
      Todo lo que hacemos, agrupado por categoría. ¿Buscas algo único para
      un evento o regalo corporativo? Visita
      <a href="/personalizados" class="text-accent hover:underline"
        >Souvenirs y Corporativos</a
      >.
    </p>

    {
      sections.map(({ title, href, cats }) => {
        const items = all.filter((p) => cats.includes(p.data.category));
        if (items.length === 0) return null;
        return (
          <div class="mt-12">
            <div class="flex items-end justify-between mb-5">
              <h2 class="font-display text-2xl md:text-3xl">{title}</h2>
              {href && (
                <a
                  href={href}
                  class="text-sm text-accent hover:underline whitespace-nowrap"
                >
                  Ver todos →
                </a>
              )}
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {items.map((p) => (
                <ProductCard product={p} />
              ))}
            </div>
          </div>
        );
      })
    }

    {
      all.length === 0 && (
        <p class="text-muted mt-8">No hay productos disponibles por ahora.</p>
      )
    }
  </section>
</BaseLayout>
