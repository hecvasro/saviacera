# Project environment loader.
#
# - .env.local holds Astro/Vite site env (PUBLIC_* values, etc.). It's picked up
#   automatically by `astro dev` / `astro build` via Vite's dotenv loader, and
#   loaded here too so anything that shells out (npm scripts, direct CLI calls)
#   sees the same values.
# - .envrc.local holds deploy-only secrets (Cloudflare API token, etc.) that
#   should never be exposed to the Astro/Vite build pipeline.
#
# Both files are gitignored. Copy `.envrc.local.example` to `.envrc.local` and
# fill in real values, then run `direnv allow` once.

dotenv_if_exists .env.local
source_env_if_exists .envrc.local
